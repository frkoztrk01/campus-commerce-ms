{
  "uid": "traffic-dashboard",
  "title": "Campus Commerce MS - Traffic Dashboard",
  "tags": ["microservices", "traffic"],
  "timezone": "browser",
  "refresh": "5s",
  "panels": [
    {
      "title": "Total Requests Rate",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_requests_total[1m])",
          "legendFormat": "{{method}} {{route_group}} ({{status_code}})"
        }
      ]
    },
    {
      "title": "Average Request Latency",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_request_duration_seconds_sum[1m]) / rate(http_request_duration_seconds_count[1m])",
          "legendFormat": "{{method}} {{route_group}}"
        }
      ]
    },
    {
      "title": "Traffic Load by Service",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m])) by (route_group)",
          "legendFormat": "{{route_group}}"
        }
      ]
    }
  ]
}
